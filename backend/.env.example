# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=*

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=chilon

# Admin auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10
